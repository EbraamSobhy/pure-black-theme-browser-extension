{
    "manifest_version": 3,
    "name": "Pure Black Theme",
    "version": "1.0",
    "description": "Turns Google Search into a true black theme.",
    "content_scripts": [
        {
            "matches": [
                "https://www.google.com/search*"
            ],
            "css": [
                "style.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}
